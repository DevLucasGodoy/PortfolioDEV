# Destination email for the contact form (formsubmit.co). Exposed in the client bundle by design.
NEXT_PUBLIC_FORMSUBMIT_EMAIL=your-email@example.com

# Password for the route gate (protectedRoutes in once-ui.config.ts). Required only if you protect routes.
PAGE_ACCESS_PASSWORD=

# Secret used to sign the auth cookie. REQUIRED whenever the password gate is used.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
